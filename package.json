{
  "name": "pinaymate",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "check:dependency-audit": "npm audit --audit-level=moderate",
    "check:launch-claims": "node scripts/check-launch-claims.mjs",
    "check:launch-claims:report": "node scripts/check-launch-claims.mjs --write-report",
    "check:local-quality": "npm run lint && npx tsc -p tsconfig.app.json --noEmit --pretty false && npm run build && npm run check:release-local",
    "check:local-links": "node scripts/check-local-cta-links.mjs",
    "check:local-links:report": "node scripts/check-local-cta-links.mjs --write-report",
    "check:product-design-contract": "node scripts/check-product-design-contract.mjs",
    "check:release-local": "npm run check:dependency-audit && npm run check:local-links && npm run check:launch-claims && npm run check:product-design-contract",
    "check:release-local:report": "npm run check:dependency-audit && npm run check:local-links:report && npm run check:launch-claims:report && npm run check:product-design-contract",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.12",
    "lucide-react": "^0.545.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "tailwindcss": "^4.1.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.33.0",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.0",
    "eslint": "^9.33.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.39.1",
    "vite": "^7.1.2"
  }
}
